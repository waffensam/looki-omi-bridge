{
  "name": "looki-omi-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Omi app for manually importing Looki moments into Omi memories and conversations.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx scripts/import-worker.ts",
    "worker:once": "tsx scripts/import-worker.ts --once",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts",
    "format:check": "prettier --check \"**/*.{ts,json,md}\""
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.81.1",
    "lucide-react": "^0.555.0",
    "next": "^16.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
