# Copy to .env.local before running the app.
# Never commit real credentials.

# Local app
APP_BASE_URL=http://localhost:3000
APP_HOME_URL=http://localhost:3000
OMI_AUTH_URL=http://localhost:3000/api/oauth/start
OMI_OAUTH_CALLBACK_URL=http://localhost:3000/api/oauth/callback
SETUP_COMPLETED_URL=http://localhost:3000/api/setup-status
APP_ENCRYPTION_KEY=
LOCAL_APP_STORE_PATH=./data/app-store.json

# Supabase store, optional for local runs and expected for hosted runs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Looki defaults. The UI saves per-user base_url and API key.
LOOKI_BASE_URL=https://open.looki.ai/api/v1
LOOKI_API_KEY=
LOOKI_SKIP_VERIFY=false

# Bailian Paraformer recording-file ASR
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com
BAILIAN_API_KEY=
# DASHSCOPE_API_KEY is also accepted when BAILIAN_API_KEY is empty.
DASHSCOPE_API_KEY=
BAILIAN_ASR_MODEL=paraformer-v2
BAILIAN_LANGUAGE_HINTS=zh,en
BAILIAN_DIARIZATION_ENABLED=false

# XFYun recording-file ASR large model, kept as a fallback.
XFYUN_BASE_URL=https://office-api-ist-dx.iflyaisol.com
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_LANGUAGE=autodialect

# AI providers
# managed -> use app/project credentials. user_key/subscription are planned modes.
AI_PROVIDER_MODE=managed
ASR_PROVIDER=bailian
MULTIMODAL_PROVIDER=managed
MULTIMODAL_MODEL=
OCR_PROVIDER=managed

# Omi App Integration API
OMI_API_BASE_URL=https://api.omi.me
OMI_APP_ID=
OMI_APP_API_KEY=

# Runtime
TEMP_AUDIO_DIR=
DRY_RUN=false
LOOKI_API_TIMEOUT_MS=30000
LOOKI_DOWNLOAD_TIMEOUT_MS=120000
OMI_API_TIMEOUT_MS=30000
OMI_VERIFY_TIMEOUT_MS=10000
XFYUN_UPLOAD_TIMEOUT_MS=120000
XFYUN_RESULT_TIMEOUT_MS=20000
XFYUN_POLL_INTERVAL_MS=3000
XFYUN_POLL_TIMEOUT_MS=900000
BAILIAN_SUBMIT_TIMEOUT_MS=30000
BAILIAN_QUERY_TIMEOUT_MS=30000
BAILIAN_RESULT_TIMEOUT_MS=60000
BAILIAN_POLL_INTERVAL_MS=3000
BAILIAN_POLL_TIMEOUT_MS=900000
IMPORT_WORKER_POLL_INTERVAL_MS=10000
IMPORT_WORKER_STALE_PROCESSING_MS=1800000
