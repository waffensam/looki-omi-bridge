{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.looki-omi-bridge/schemas/omi-from-segments.schema.json",
  "title": "Omi From Segments Payload",
  "type": "object",
  "required": ["source", "language", "started_at", "transcript_segments"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "const": "unknown"
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "geolocation": {
      "type": "object"
    },
    "transcript_segments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": ["text", "speaker", "is_user", "start", "end"],
        "additionalProperties": false,
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "speaker": {
            "type": "string",
            "pattern": "^SPEAKER_[0-9]{2}$"
          },
          "speaker_id": {
            "type": "integer",
            "minimum": 0
          },
          "is_user": {
            "type": "boolean"
          },
          "person_id": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    }
  }
}
