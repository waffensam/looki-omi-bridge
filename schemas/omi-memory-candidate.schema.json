{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.looki-omi-bridge/schemas/omi-memory-candidate.schema.json",
  "title": "Omi Memory Candidate",
  "type": "object",
  "required": [
    "idempotencyKey",
    "content",
    "eventDate",
    "sourceKind",
    "sourceMomentIds",
    "eventType",
    "confidence",
    "evidenceDepth",
    "writePolicy",
    "visibility",
    "tags",
    "contextSummary",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "idempotencyKey": {
      "type": "string",
      "pattern": "^looki:memory:.+:.+$"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "Omi memory body. Do not prefix with the event date; date belongs in eventDate and tags."
    },
    "eventDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "sourceKind": {
      "enum": [
        "daily_timeline",
        "audio",
        "video",
        "multimodal_cluster",
        "for_you_enriched_moment",
        "for_you"
      ]
    },
    "sourceMomentIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forYouItemIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidenceDepth": {
      "enum": [
        "moment_summary",
        "for_you_enriched_summary",
        "targeted_media_required",
        "targeted_media",
        "user_review"
      ]
    },
    "writePolicy": {
      "enum": ["auto_write", "stage_only", "never_write"]
    },
    "visibility": {
      "enum": ["private", "public"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "headline": {
      "type": "string",
      "maxLength": 40
    },
    "contextSummary": {
      "type": "string",
      "minLength": 1
    },
    "currentActivity": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "summary"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "enum": [
              "visual",
              "asr",
              "ocr",
              "timeline",
              "for_you",
              "user_review"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "sourceMomentId": {
            "type": "string"
          },
          "sourceForYouItemId": {
            "type": "string"
          }
        }
      }
    }
  }
}
